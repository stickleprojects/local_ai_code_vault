# Copy to .env and adjust. `.env` is gitignored.
#   cp .env.example .env

# --- Embedding model (B-1 locked: nomic-embed-code Q4_K_M GGUF) --------
# Vendored from Hugging Face into the `model_cache` volume, NOT Ollama.
MODEL_REPO=nomic-ai/nomic-embed-code-GGUF
MODEL_FILE=nomic-embed-code.Q4_K_M.gguf
HF_BASE=https://huggingface.co

# SHA256 the download is verified against (the model-fetch step refuses
# to start the embedder on a mismatch). This is the B-1-proven Q4_K_M
# content hash. If Hugging Face repackages this file the hash will move:
# re-verify a trusted copy, then update this value (see README_SETUP.md).
MODEL_SHA256=4354a73ee9ff5d811efe552a515dfd518667ff25fdfc4ee9e10af3f617f96eec

# --- Host port mappings ----------------------------------------------
API_PORT=8000
# Qdrant is reached in-network by the api; exposed only for debugging.
QDRANT_PORT=6333
